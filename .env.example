# === Required ===
# Anthropic API key — app refuses to start without this
ANTHROPIC_API_KEY=sk-ant-...

# === Optional — ScienceDirect ingestion ===
# Leave blank to run in offline mode (mock data only)
# The /chat endpoint never needs this key; only /ingest and the ingestion scripts do
SCIENCEDIRECT_API_KEY=

# Springer Nature API key (optional — works alongside or instead of ScienceDirect)
# Get your key at: https://dev.springernature.com/
SPRINGER_NATURE_API_KEY=

# === App settings ===
# Seed Chroma with mock data on startup if collection is empty
USE_MOCK_DATA=true

# Path for ChromaDB persistence
CHROMA_PATH=./chroma_store

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Enable cross-encoder reranking (set false to skip and use cosine order)
USE_RERANKER=true

# Claude model — claude-sonnet-4-6 for quality, claude-haiku-4-5-20251001 for speed
CLAUDE_MODEL=claude-sonnet-4-6

# CORS origin for the frontend (Next.js dev server)
FRONTEND_ORIGIN=http://localhost:4000
